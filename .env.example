# ─────────────────────────────────────────────────────────────
#  Career Guidance Bot — Environment Variables
#  Copy this file to .env and fill in your values
#  Never commit .env to Git (it's in .gitignore)
# ─────────────────────────────────────────────────────────────

# Server port (local development)
PORT=3001

# Node environment
NODE_ENV=development

# ── Optional: Dialogflow Service Account (for server-side auth) ──────────────
# Only needed if you want to send queries TO Dialogflow from server
# DIALOGFLOW_PROJECT_ID=your-project-id
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ── Optional: Database (for persistent analytics) ────────────────────────────
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/careerbot
# REDIS_URL=redis://localhost:6379

# ── Optional: Admin dashboard auth ───────────────────────────────────────────
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=your-secure-password

# ── Optional: Rate limiting ───────────────────────────────────────────────────
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100

# ── Vercel will auto-inject these in production ───────────────────────────────
# VERCEL_URL=your-app.vercel.app
